#loading
  position: fixed
  top: 0
  left: 0
  width: 100vw
  height: 100vh
  z-index: 99999
  overflow: hidden

#loading-page
  position: absolute
  top: 0
  right: 0
  bottom: 0
  left: 0
  display: flex
  align-items: center
  justify-content: center
  background: linear-gradient(35deg, #fd747c 10%, #ff74a0 65%, #ffc329 125%)
  transition: opacity 1s

#phrase_box
  display: flex
  flex-flow: column
  width: 280px
  height: 150px
  overflow: hidden
  filter: drop-shadow(0 18px 42px rgba(146, 32, 68, .18))

#phrases
  will-change: transform

.loading-phrase-text
  fill: #fff
  font-family: Mulish, Arial, "PingFang SC", "Microsoft YaHei", sans-serif
  font-size: 18px
  font-weight: 700
  letter-spacing: .03em

.loading-check-circle
  fill: rgba(255, 255, 255, 0)

.loading-check-mark
  fill: #fff

.loading-check-outline
  fill: #fff

.loading-footer
  position: fixed
  right: 0
  bottom: 30px
  left: 0
  display: flex
  align-items: center
  justify-content: center
  gap: .65rem
  color: #fff
  font-family: Mulish, Arial, "PingFang SC", "Microsoft YaHei", sans-serif
  font-size: .9rem
  font-weight: 800
  letter-spacing: .18em
  text-transform: uppercase
  text-shadow: 0 10px 30px rgba(120, 20, 54, .28)

.loading-logo
  width: 16px
  height: 16px
  border: 2px solid rgba(255, 255, 255, .88)
  border-radius: 50%
  position: relative
  box-shadow: 0 0 0 5px rgba(255, 255, 255, .12)

.loading-logo::after
  content: ""
  position: absolute
  top: 3px
  left: 3px
  width: 6px
  height: 6px
  border-radius: 50%
  background: #fff

@media (max-width: 767px)
  #phrase_box
    width: 240px
  .loading-phrase-text
    font-size: 16px
  .loading-footer
    bottom: 24px
    font-size: .78rem

@media (prefers-reduced-motion: reduce)
  #phrases
    transform: translateY(0) !important
